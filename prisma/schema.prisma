generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Unit {
  g
  kg
  ml
  L
  pcs
  oz
  lb
}

enum OrderStatus {
  NEW
  PROCESSING
  PACKING
  READY
  DELIVERED
  CANCELLED
}

enum OrderPaymentMethod {
  CASH
  CARD
  PHONEPE
}

enum OrderChannel {
  DINE_IN
  ONLINE
}

enum DineInPaymentTiming {
  UPFRONT
  AT_CLOSE
}

enum ReservationStatus {
  PENDING
  SEATED
  CANCELLED
  NO_SHOW
}

enum ExpenseCategory {
  RENT
  SALARIES
  UTILITIES
  SUPPLIES
  MARKETING
  EQUIPMENT
  INSURANCE
  MAINTENANCE
  OTHER
}

enum PurchasePaymentStatus {
  PAID
  CREDIT
  PARTIAL
}

enum DiscountType {
  PERCENT
  FIXED
}

enum UserRole {
  OWNER
  MANAGER
  POS
  KITCHEN
  VIEWER
}

model Business {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  timezone  String   @default("Asia/Kolkata")
  currency  String   @default("INR") @db.VarChar(3)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships   UserBusiness[]
  diningTables  DiningTable[]
  ingredients   Ingredient[]
  suppliers     Supplier[]
  customers     Customer[]
  discounts     Discount[]
  inventoryItems InventoryItem[]
  recipes       Recipe[]
  orders        Order[]
  reservations  TableReservation[]
  expenses      Expense[]
  settings      AppSetting[]

  @@map("businesses")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(POS)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships UserBusiness[]

  @@index([role])
  @@index([isActive])
  @@map("users")
}

model UserBusiness {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  role       UserRole
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([businessId])
  @@map("user_businesses")
}

model DiningTable {
  id         String   @id @default(cuid())
  businessId String
  code       String
  label      String
  section    String?
  capacity   Int?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business     Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  orders       Order[]
  reservations TableReservation[]

  @@unique([businessId, code])
  @@index([businessId, isActive])
  @@map("dining_tables")
}

model TableReservation {
  id              String            @id @default(cuid())
  businessId      String
  diningTableId   String?
  guestName       String
  phone           String?
  partySize       Int               @default(2)
  reservedAt      DateTime
  durationMinutes Int               @default(90)
  status          ReservationStatus @default(PENDING)
  notes           String?           @db.Text
  orderId         String?           @unique
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  business    Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  diningTable DiningTable? @relation(fields: [diningTableId], references: [id], onDelete: SetNull)
  order       Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([businessId, reservedAt])
  @@index([businessId, status])
  @@index([diningTableId])
  @@map("table_reservations")
}

model Ingredient {
  id             String   @id @default(cuid())
  businessId     String
  name           String
  normalizedName String
  sku            String
  barcode        String
  category       String
  defaultUnit    Unit
  aliases        String?  @db.Text
  notes          String?  @db.Text
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  business          Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  inventoryItems    InventoryItem[]
  recipeIngredients RecipeIngredient[]

  @@unique([businessId, normalizedName])
  @@unique([businessId, sku])
  @@unique([businessId, barcode])
  @@index([businessId, category])
  @@index([businessId, isActive])
  @@map("ingredients")
}

model Supplier {
  id           String   @id @default(cuid())
  businessId   String
  name         String
  contactPhone String?
  email        String?
  address      String?  @db.Text
  notes        String?  @db.Text
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business       Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  purchases      InventoryPurchase[]
  inventoryItems InventoryItem[]

  @@index([businessId, isActive])
  @@map("suppliers")
}

model Customer {
  id         String   @id @default(cuid())
  businessId String
  name       String
  phone      String?
  email      String?
  notes      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  orders   Order[]

  @@index([businessId, name])
  @@map("customers")
}

model Discount {
  id             String       @id @default(cuid())
  businessId     String
  code           String
  name           String
  type           DiscountType
  value          Decimal      @db.Decimal(12, 4)
  minOrderAmount Decimal?     @db.Decimal(12, 4)
  isActive       Boolean      @default(true)
  validFrom      DateTime?    @db.Date
  validTo        DateTime?    @db.Date
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  orders   Order[]

  @@unique([businessId, code])
  @@index([businessId, isActive])
  @@map("discounts")
}

model InventoryItem {
  id              String   @id @default(cuid())
  businessId      String
  ingredientId    String?
  supplierId      String?
  name            String
  sku             String
  category        String
  description     String?  @db.Text
  notes           String?  @db.Text
  quantity        Decimal  @db.Decimal(12, 4)
  unit            Unit
  reorderLevel    Decimal  @db.Decimal(12, 4)
  costPerUnit     Decimal  @db.Decimal(12, 4)
  supplier        String?
  storageLocation String?
  expiryDate      DateTime?
  batchNumber     String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business           Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  ingredient         Ingredient?            @relation(fields: [ingredientId], references: [id], onDelete: SetNull)
  supplierRef        Supplier?              @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  recipeIngredients  RecipeIngredient[]
  costHistory        InventoryCostHistory[]
  orderConsumptions  OrderLineConsumption[]
  purchases          InventoryPurchase[]

  @@unique([businessId, sku])
  @@index([businessId, ingredientId])
  @@index([businessId, supplierId])
  @@index([businessId, category])
  @@index([businessId, isActive])
  @@map("inventory_items")
}

model InventoryCostHistory {
  id              String   @id @default(cuid())
  inventoryItemId String
  costPerUnit     Decimal  @db.Decimal(12, 4)
  previousCost    Decimal? @db.Decimal(12, 4)
  effectiveAt     DateTime @default(now())
  note            String?

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([inventoryItemId])
  @@index([effectiveAt])
  @@map("inventory_cost_history")
}

model Recipe {
  id            String   @id @default(cuid())
  businessId    String
  name          String
  description   String?  @db.Text
  category      String
  imageUrl      String?
  yieldQuantity Decimal  @db.Decimal(12, 4)
  yieldUnit     String
  instructions  String?  @db.Text
  salePrice        Decimal? @db.Decimal(12, 4)
  prepTimeMinutes  Int?
  barcode          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business       Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  ingredients    RecipeIngredient[]
  orderLineItems OrderLineItem[]

  @@unique([businessId, barcode])
  @@index([businessId, category])
  @@map("recipes")
}

model RecipeIngredient {
  id               String  @id @default(cuid())
  recipeId         String
  ingredientId     String
  inventoryItemId  String?
  quantityRequired Decimal @db.Decimal(12, 4)
  unit             Unit

  recipe        Recipe         @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient    Ingredient     @relation(fields: [ingredientId], references: [id], onDelete: Restrict)
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)

  @@index([recipeId])
  @@index([ingredientId])
  @@index([inventoryItemId])
  @@map("recipe_ingredients")
}

model Order {
  id             String               @id @default(cuid())
  businessId     String
  orderNumber    String
  channel        OrderChannel         @default(DINE_IN)
  diningTableId  String?
  tableLabel     String?
  externalRef    String?
  customerId     String?
  customerName   String?
  covers         Int?
  discountId     String?
  discountCode   String?
  subtotal       Decimal?             @db.Decimal(12, 4)
  discountTotal  Decimal              @default(0) @db.Decimal(12, 4)
  pricesIncludeTax Boolean            @default(true)
  gstRatePercent Decimal?             @db.Decimal(5, 2)
  taxSupplyType  String?              @db.VarChar(32)
  taxableAmount  Decimal?             @db.Decimal(12, 4)
  cgstPercent    Decimal?             @db.Decimal(5, 2)
  sgstPercent    Decimal?             @db.Decimal(5, 2)
  igstPercent    Decimal?             @db.Decimal(5, 2)
  cgstAmount     Decimal              @default(0) @db.Decimal(12, 4)
  sgstAmount     Decimal              @default(0) @db.Decimal(12, 4)
  igstAmount     Decimal              @default(0) @db.Decimal(12, 4)
  taxTotal       Decimal              @default(0) @db.Decimal(12, 4)
  tipAmount      Decimal              @default(0) @db.Decimal(12, 4)
  grandTotal     Decimal?             @db.Decimal(12, 4)
  taxGstin       String?              @db.VarChar(20)
  taxLegalName   String?              @db.VarChar(255)
  paymentMethod  OrderPaymentMethod?
  paidAt         DateTime?
  notes          String?              @db.Text
  status         OrderStatus          @default(NEW)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  processedAt    DateTime?
  packingAt      DateTime?
  readyAt        DateTime?
  deliveredAt    DateTime?
  cancelledAt    DateTime?
  cancelReason   String?          @db.Text
  /// Cook tapped "Got it" after a bump (new items / qty).
  kitchenAcknowledgedAt DateTime?
  /// Set when items are added or qty increases — sorts ticket to top on KDS.
  kitchenBumpedAt       DateTime?

  business    Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  diningTable DiningTable? @relation(fields: [diningTableId], references: [id], onDelete: SetNull)
  customer    Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  discount    Discount?    @relation(fields: [discountId], references: [id], onDelete: SetNull)
  lineItems    OrderLineItem[]
  reservation  TableReservation?

  @@unique([businessId, orderNumber])
  @@index([businessId, status])
  @@index([businessId, createdAt])
  @@index([businessId, channel])
  @@index([customerId])
  @@map("orders")
}

model OrderLineItem {
  id              String   @id @default(cuid())
  orderId         String
  recipeId        String?
  recipeName      String
  quantity        Int
  unitSalePrice   Decimal  @db.Decimal(12, 4)
  ingredientCost  Decimal? @db.Decimal(12, 4)
  revenue         Decimal? @db.Decimal(12, 4)
  profit          Decimal? @db.Decimal(12, 4)
  processedAt     DateTime?
  /// When this line (or extra qty) was sent to kitchen.
  addedAt         DateTime @default(now())
  /// Cook marked this line finished on KDS (separate from inventory processedAt).
  kitchenDoneAt   DateTime?
  /// Units marked done on KDS (0..quantity); survives qty bumps on open tabs.
  kitchenDoneQty  Int      @default(0)

  order        Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  recipe       Recipe?                @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  consumptions OrderLineConsumption[]

  @@index([orderId])
  @@index([recipeId])
  @@map("order_line_items")
}

model OrderLineConsumption {
  id               String  @id @default(cuid())
  orderLineItemId  String
  inventoryItemId  String
  quantityDeducted Decimal @db.Decimal(12, 4)
  unit             Unit
  costPerUnit      Decimal @db.Decimal(12, 4)
  lineCost         Decimal @db.Decimal(12, 4)

  orderLineItem OrderLineItem @relation(fields: [orderLineItemId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@index([orderLineItemId])
  @@index([inventoryItemId])
  @@map("order_line_consumptions")
}

model InventoryPurchase {
  id              String                @id @default(cuid())
  inventoryItemId String?
  supplierId      String?
  receiveBatchId  String?
  description     String
  supplier        String?
  totalAmount     Decimal               @db.Decimal(12, 4)
  amountPaid      Decimal               @default(0) @db.Decimal(12, 4)
  paymentStatus   PurchasePaymentStatus @default(PAID)
  purchaseDate    DateTime              @db.Date
  dueDate         DateTime?             @db.Date
  notes           String?               @db.Text
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  supplierRef   Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([inventoryItemId])
  @@index([supplierId])
  @@index([paymentStatus])
  @@index([purchaseDate])
  @@index([receiveBatchId])
  @@map("inventory_purchases")
}

model Expense {
  id          String          @id @default(cuid())
  businessId  String
  category    ExpenseCategory
  description String
  amount      Decimal         @db.Decimal(12, 4)
  periodMonth String          @db.VarChar(7)
  expenseDate DateTime?       @db.Date
  notes       String?         @db.Text
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, periodMonth])
  @@index([expenseDate])
  @@index([category])
  @@map("expenses")
}

model AppSetting {
  id         String   @id @default(cuid())
  businessId String
  key        String
  value      String   @db.Text
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, key])
  @@map("app_settings")
}

model AuditLog {
  id         String   @id @default(cuid())
  businessId String?
  action     String
  entity     String
  entityId   String?
  details    String?  @db.Text
  actorRole  String?
  createdAt  DateTime @default(now())

  @@index([entity, createdAt])
  @@index([businessId])
  @@map("audit_logs")
}
