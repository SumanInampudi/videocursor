DATABASE_URL="mysql://root:password@localhost:3306/servora_inventory"

# Required in production — used to sign login cookies
SESSION_SECRET="generate-a-long-random-string"

# Optional: default password for demo users created by `npm run db:seed`
SEED_ADMIN_PASSWORD="changeme"

# Development only — skip login when no users exist yet
# AUTH_DISABLED="true"

# Development only — simulate a role without logging in (owner|manager|pos|kitchen|viewer)
# APP_ROLE="owner"

# Public customer queue display — venue slug (default redirects /queue → /queue/demo)
# PUBLIC_QUEUE_SLUG="demo"
